{
    "name": "teddy",
    "version": "0.0.15",
    "description": "Opinionated open-source content management system (CMS) and static site generator (SSG) that focuses on simplicity and easy content management.",
    "engines": {
        "node": ">=24.11.1"
    }, 
    "main": "build.js",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "node build.js",
        "build:demo": "node build.js --site-name travelbook --theme-name bear",
        "test": "vitest run --config ./system/tests/vitest.config.js", 
        "test:watch": "vitest --config ./system/tests/vitest.config.js", 
        "upgrade": "node upgrade.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/teddyful/teddy.git"
    },
    "author": "Jillur Quddus",
    "license": "GPL-3.0",
    "bugs": {
        "url": "https://github.com/teddyful/teddy/issues"
    },
    "homepage": "https://teddyful.com",
    "devDependencies": {
        "ajv": "8.20.0",
        "commander": "15.0.0",
        "del": "8.0.1",
        "flexsearch": "0.8.212",
        "gulp": "5.0.1",
        "gulp-mustache": "5.0.0",
        "minify": "15.3.1",
        "pdfkit": "0.19.1",
        "prompt-sync": "4.2.0",
        "semver": "7.8.5",
        "sha256-file": "1.0.0",
        "showdown": "2.1.0",
        "string-strip-html": "13.5.3",
        "try-to-catch": "4.0.5",
        "unzipper": "0.12.5", 
        "vite": "7.3.5",
        "vitest": "4.1.9",
        "winston": "3.19.0",
        "winston-daily-rotate-file": "5.0.0",
        "wrangler": "^4.103.0"
    }
}
